generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

model User {
  id       String @id @default(cuid())
  fullName String
  email    String @unique
  password String
  role     Role   @default(STUDENT)

  tasks      Task[]
  attendance Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Attendance {
  id String @id @default(cuid())

  subject    String
  percentage Int

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Notice {
  id String @id @default(cuid())

  title       String
  description String

  createdAt DateTime @default(now())
}

model Note {
  id String @id @default(cuid())

  title   String
  fileUrl String

  createdAt DateTime @default(now())
}

model Timetable {
  id String @id @default(cuid())

  subject   String
  day       String
  startTime String
  endTime   String

  createdAt DateTime @default(now())
}
